{
  "name": "@nomicfoundation/hardhat-ignition",
  "version": "3.1.8",
  "description": "Hardhat Ignition is a declarative system for deploying smart contracts on Ethereum. It enables you to define smart contract instances you want to deploy, and any operation you want to run on them. By taking over the deployment and execution, Hardhat Ignition lets you focus on your project instead of getting caught up in the deployment details.",
  "homepage": "https://github.com/NomicFoundation/hardhat/tree/main/packages/hardhat-ignition",
  "repository": {
    "type": "git",
    "url": "https://github.com/NomicFoundation/hardhat",
    "directory": "packages/hardhat-ignition"
  },
  "author": "Nomic Foundation",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./modules": "./dist/src/modules.js",
    "./helpers": "./dist/src/helpers.js",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "modules": [
        "./dist/src/modules.d.ts"
      ],
      "helpers": [
        "./dist/src/helpers.d.ts"
      ]
    }
  },
  "keywords": [
    "ethereum",
    "smart-contracts",
    "hardhat",
    "blockchain",
    "dapps",
    "tooling",
    "solidity",
    "deployment"
  ],
  "scripts": {
    "lint": "pnpm eslint && pnpm prettier --check",
    "lint:fix": "pnpm eslint --fix && pnpm prettier --write",
    "eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --ignore-pattern \"**/*.d.ts\"",
    "prettier": "prettier \"**/*.{ts,js,md,json}\"",
    "pretest": "pnpm run --dir ../ignition-ui prepack",
    "test": "mocha --recursive \"test/**/*.ts\"",
    "test:coverage": "nyc mocha \"test/**/*.ts\"",
    "test:build": "tsc --project ./test/",
    "prepack": "pnpm build",
    "build": "tsc --build .",
    "clean": "rimraf .nyc_output coverage dist tsconfig.tsbuildinfo ./test/fixture-projects/**/deployments ./test/fixture-projects/**/artifacts ./test/fixture-projects/**/cache ./test/fixture-projects/*-tmp-*-*-*-*-*"
  },
  "files": [
    "dist/src/",
    "src/",
    "CHANGELOG.md",
    "README.md"
  ],
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "1.0.2",
    "@nomicfoundation/hardhat-network-helpers": "workspace:^3.0.11",
    "@nomicfoundation/hardhat-test-utils": "workspace:^",
    "@nomicfoundation/hardhat-verify": "workspace:^3.0.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.1",
    "@types/mocha": ">=10.0.10",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.2",
    "@types/sinon": "^22.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.0",
    "cross-env": "7.0.3",
    "eslint": "9.25.1",
    "hardhat": "workspace:^3.8.0",
    "mocha": "^11.0.0",
    "nyc": "15.1.0",
    "prettier": "3.2.5",
    "rimraf": "^5.0.5",
    "sinon": "^22.0.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "viem": "^2.47.6"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-errors": "workspace:^3.0.16",
    "@nomicfoundation/hardhat-utils": "workspace:^4.1.4",
    "@nomicfoundation/ignition-core": "workspace:^3.1.8",
    "@nomicfoundation/ignition-ui": "workspace:^3.1.2",
    "json5": "^2.2.3",
    "prompts": "^2.4.2"
  },
  "peerDependencies": {
    "@nomicfoundation/hardhat-verify": "workspace:^3.0.0",
    "hardhat": "workspace:^3.8.0"
  }
}
