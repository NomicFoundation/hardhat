{
  "$schema": "../../scripts/end-to-end/schema/scenario.schema.json",
  "description": "A fork of OpenZeppelin's Hardhat 3 branch including their Mocha test suite.",
  "tags": ["external-repo", "mocha"],
  "repo": "nomicfoundation/openzeppelin-contracts",
  "commit": "f72b6b4616806a0cb29eb61d6baf05ab5ff01558",
  "packageManager": "npm",
  "submodules": true,
  "preinstall": "./preinstall.sh",
  "defaultCommand": "npx hardhat test mocha",
  "benchmark": {
    "skip": true,
    "commands": {
      "cold compile": {
        "runs": 3,
        "prepare": "npx hardhat clean",
        "command": "npx hardhat compile"
      },
      "warm compile": {
        "runs": 19,
        "command": "npx hardhat compile"
      },
      "mocha test": {
        "runs": 3,
        "command": "npx hardhat test mocha --no-compile"
      }
    }
  }
}
