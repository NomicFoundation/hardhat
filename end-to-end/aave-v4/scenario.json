{
  "$schema": "../../scripts/end-to-end/schema/scenario.schema.json",
  "description": "Aave v4 fork to Hardhat 3.",
  "tags": ["external-repo"],
  "repo": "anaPerezGhiglia/aave-v4",
  "commit": "f729aeff7cc61d576e8f89e818e05265ec9f65e9",
  "packageManager": "yarn",
  "submodules": true,
  "preinstall": "./preinstall.sh",
  "defaultCommand": "npx hardhat test solidity",
  "benchmark": {
    "commands": {
      "cold compile": {
        "runs": 3,
        "prepare": "npx hardhat clean",
        "command": "npx hardhat compile"
      },
      "warm compile": {
        "runs": 39,
        "command": "npx hardhat compile"
      },
      "test solidity": {
        "runs": 3,
        "command": "npx hardhat test solidity --no-compile"
      }
    }
  }
}
