{
  "$schema": "../../scripts/end-to-end/schema/scenario.schema.json",
  "description": "Lido Dual Governance Smart contracts fork to Hardhat 3.",
  "tags": ["external-repo"],
  "repo": "popescuoctavian/dual-governance",
  "commit": "ef72db01b9b69fddc7fefae9da160e465921ec42",
  "packageManager": "npm",
  "submodules": true,
  "env": {
    "MAINNET_RPC_URL": "${localEnv:ALCHEMY_URL}"
  },
  "defaultCommand": "npx hardhat test solidity --grep=\"^(test_|testFuzz_)\"",
  "benchmark": {
    "commands": {
      "cold compile": {
        "runs": 3,
        "prepare": "npx hardhat clean",
        "command": "npx hardhat compile"
      },
      "warm compile": {
        "runs": 83,
        "command": "npx hardhat compile"
      },
      "test solidity": {
        "runs": 3,
        "command": "npx hardhat test solidity --no-compile --grep=\"^(test_|testFuzz_)\""
      }
    }
  }
}
